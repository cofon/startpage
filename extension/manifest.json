{
  "manifest_version": 3,
  "name": "cofon-startpage",
  "version": "1.0.0",
  "description": "配合起始页添加网站的扩展",
  "permissions": ["activeTab", "scripting", "tabs", "storage", "offscreen"],
  "host_permissions": [
    "http://localhost:5173/",
    "http://localhost:5174/",
    "http://localhost:5175/",
    "https://dgf.cc.cd/",
    "http://dgf.cc.cd/"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "commands": {
    "open-panel": {
      "suggested_key": {
        "default": "Alt+Shift+D"
      },
      "description": "打开添加网站面板"
    }
  }
}
