# ============================================
# EdgeOne Pages 忽略文件配置
# ============================================
# 此文件用于指定在部署到 EdgeOne Pages 时需要忽略的文件和目录
# 格式与 .gitignore 类似
# ============================================

# ============================================
# Node.js 依赖（EdgeOne 会自动安装）
# ============================================
node_modules/

# ============================================
# 本地开发服务文件（仅在本地运行，不部署）
# ============================================
server.js
local-metadata-service.js
test-*.js
test-api.js
test-api-quick.js
test-metadata.js

# ============================================
# 文档和说明文件（不需要部署）
# ============================================
*.md
README.md
GUIDE.md
TESTING.md
TEST_GUIDE.md
TROUBLESHOOTING_DEV_SERVER.md
FIX_*.md
URL_ENCODING_FIX.md
LOCAL_TEST_RESULTS.md
API_SWITCH_GUIDE.md
docs/

# ============================================
# 配置文件模板和示例（只保留实际使用的 .env）
# ============================================
.env.example
.env.production.example
.env.local

# ============================================
# 备份目录和其他临时文件
# ============================================
bak/
*.bak
*.log
temp

# ============================================
# 开发工具和编辑器配置
# ============================================
.git/
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================
# 构建产物和缓存（EdgeOne 会自动构建）
# ============================================
dist/
.cache/
.edgeone/cache/

# ============================================
# PowerShell 脚本（仅本地使用）
# ============================================
restart-edgeone.ps1

# ============================================
# 其他文本文件
# ============================================
*.txt
edgeone_智能客服对一些问题的回复.txt
